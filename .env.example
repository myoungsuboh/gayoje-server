# gayoje-server 환경변수 예시 — 실제 값(시크릿) 없이 "키 이름만".
# 사용법: cp .env.example .env  후 각 값을 채운다. .env 는 절대 커밋 금지(.gitignore).

# ===== 실행 환경 =====
ENV=development                 # development | production
PORT=8000

# ===== JWT 인증 =====
# 운영 환경에서는 반드시 충분히 긴 무작위 문자열로 교체 (openssl rand -hex 32)
JWT_SECRET_KEY=change-me-to-a-long-random-secret-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== CORS (콤마 구분, 와일드카드 "*") =====
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ===== Neo4j (관계 그래프) =====
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# ===== Redis (arq 큐 + JWT jti 블랙리스트) =====
REDIS_URL=redis://localhost:6379/0

# ===== arq 튜닝 =====
ARQ_QUEUE_NAME=gayoje:jobs
ARQ_MAX_JOBS=2
ARQ_MAX_TRIES=3
ARQ_JOB_TIMEOUT_SEC=300
ARQ_KEEP_RESULT_SEC=3600

# ===== LLM (LiteLLM proxy 경유 권장, 미설정 시 단일키 직접 호출) =====
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# LITELLM_PROXY_URL=http://localhost:4000
# LITELLM_MASTER_KEY=

# ===== 토큰 컬럼 암호화 (Fernet) =====
TOKEN_ENCRYPTION_KEY=

# ===== Swagger UI Basic Auth (ENV=production 에서만 동작) =====
DOCS_USERNAME=admin
DOCS_PASSWORD=

# ===== OAuth (가요제: 카카오 / 네이버) — adapt 예정 =====
# KAKAO_OAUTH_CLIENT_ID=
# KAKAO_OAUTH_CLIENT_SECRET=
# KAKAO_OAUTH_REDIRECT_URI=
# NAVER_OAUTH_CLIENT_ID=
# NAVER_OAUTH_CLIENT_SECRET=
# NAVER_OAUTH_REDIRECT_URI=

# ===== 결제 (토스 결제위젯) — adapt 예정 =====
# TOSS_CLIENT_KEY=
# TOSS_SECRET_KEY=
# TOSS_WEBHOOK_SECRET=

# ===== 이메일 (선택) =====
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=가요제 <onboarding@resend.dev>
# PASSWORD_RESET_URL=

# ===== FE base URL (초대/리셋 링크) =====
FRONTEND_URL=http://localhost:5173

# ===== 관측성 =====
LOG_FORMAT=text                 # text | json
LOG_LEVEL=INFO
# SENTRY_DSN=
METRICS_ENABLED=true
