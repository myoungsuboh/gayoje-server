        "id": "API-01",
        "name": "식물 생장 데이터 조회",
        "method": "GET",
        "endpoint": "/api/v1/plants/{plantId}/growth-data",
        "description": "특정 식물의 생장 데이터를 조회한다.",
        "related_story_id": "Story-03.1",
