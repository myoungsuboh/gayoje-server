          {"name": "plantId", "type": "uuid", "required": true, "constraint": "", "description": "식물 식별자"}
        ],
        "query_params": [
          {"name": "from", "type": "datetime", "required": false, "constraint": "", "description": "조회 시작 시점 (UTC)"},
          {"name": "to",   "type": "datetime", "required": false, "constraint": "", "description": "조회 종료 시점 (UTC)"}
        ],
        "request_body": {"content_type": "", "fields": [], "example": ""},
        "response_body": {
          "status": 200, "content_type": "application/json",
          "fields": [
            {"name": "items", "type": "array", "required": true, "constraint": "item: PlantGrowthData", "description": "생장 데이터 목록"}
          ],
          "example": "{\"items\": [...]}"
        },
        "error_cases": [
          {"status": 401, "code": "AUTH_REQUIRED",     "condition": "JWT 누락/만료",       "message": "인증이 필요합니다",       "lineage_quote": ""},
          {"status": 403, "code": "FORBIDDEN_OWNER",   "condition": "본인 소유 아닌 식물", "message": "권한이 없습니다",         "lineage_quote": ""},
          {"status": 404, "code": "PLANT_NOT_FOUND",   "condition": "plantId 미존재",       "message": "식물을 찾을 수 없습니다", "lineage_quote": ""}
        ],
        "auth": {
          "required": true, "required_roles": ["owner", "admin"],
          "ownership_check": "Plant.ownerId == requester.userId",
          "description": "본인 식물 또는 관리자"
        }
      },
      {
        "id": "API-02",
        "name": "식물 생장 데이터 기록",
        "method": "POST",
        "endpoint": "/api/v1/plants/{plantId}/growth-data",
        "description": "특정 식물의 생장 데이터를 기록한다.",
        "related_story_id": "Story-03.2",
        "path_params": [
          {"name": "plantId", "type": "uuid", "required": true, "constraint": "", "description": "식물 식별자"}
        ],
        "query_params": [],
        "request_body": {
          "content_type": "application/json",
          "fields": [
            {"name": "height",       "type": "double",  "required": true,  "constraint": ">0",     "description": "키 (cm)"},
            {"name": "leafCount",    "type": "integer", "required": true,  "constraint": ">=0",    "description": "잎 개수"},
            {"name": "healthStatus", "type": "enum",    "required": false, "constraint": "enum: HEALTHY|WARNING|DEAD", "description": "건강 상태"}
          ],
          "example": "{\"height\": 12.5, \"leafCount\": 8, \"healthStatus\": \"HEALTHY\"}"
        },
        "response_body": {
          "status": 201, "content_type": "application/json",
          "fields": [
            {"name": "id",         "type": "uuid",     "required": true, "constraint": "", "description": "생성된 기록 ID"},
            {"name": "recordedAt", "type": "datetime", "required": true, "constraint": "", "description": "기록 시각 (UTC)"}
          ],
          "example": "{\"id\": \"...\", \"recordedAt\": \"2026-05-25T...\"}"
        },
        "error_cases": [
          {"status": 401, "code": "AUTH_REQUIRED",     "condition": "JWT 누락/만료", "message": "인증이 필요합니다",       "lineage_quote": ""},
          {"status": 403, "code": "FORBIDDEN_OWNER",   "condition": "본인 식물 아님", "message": "권한이 없습니다",         "lineage_quote": ""},
          {"status": 404, "code": "PLANT_NOT_FOUND",   "condition": "plantId 미존재", "message": "식물을 찾을 수 없습니다", "lineage_quote": ""},
          {"status": 422, "code": "VALIDATION_ERROR",  "condition": "height/leafCount 음수", "message": "잘못된 입력값", "lineage_quote": ""}
        ],
        "auth": {
          "required": true, "required_roles": ["owner"],
          "ownership_check": "Plant.ownerId == requester.userId",
          "description": "본인 식물에만 기록 가능"
        }
      },
