{
  "spack": {
    "apis": [
      {
        "id": "API-01", "name": "게시글 등록", "method": "POST", "endpoint": "/api/v1/posts",
        "description": "author 가 새 게시글을 등록한다.",
        "related_story_id": "Story-01.1",
        "path_params": [],
        "query_params": [],
        "request_body": {
          "content_type": "application/json",
          "fields": [
            {"name": "title", "type": "string", "required": true,  "constraint": "1~200자",        "description": "제목"},
            {"name": "body",  "type": "string", "required": true,  "constraint": "1~50000자",      "description": "본문"},
            {"name": "tags",  "type": "array",  "required": false, "constraint": "최대 10개, item: string 1~30자", "description": "태그"}
          ],
          "example": "{\"title\": \"오늘의 회고\", \"body\": \"...\", \"tags\": [\"diary\"]}"
        },
        "response_body": {
          "status": 201, "content_type": "application/json",
          "fields": [
            {"name": "id",        "type": "uuid",     "required": true, "constraint": "", "description": "게시글 ID"},
            {"name": "createdAt", "type": "datetime", "required": true, "constraint": "", "description": "UTC"}
          ],
          "example": "{\"id\": \"...\", \"createdAt\": \"2026-05-26T...\"}"
        },
        "error_cases": [
          {"status": 401, "code": "AUTH_REQUIRED",    "condition": "JWT 누락/만료",   "message": "인증이 필요합니다",   "lineage_quote": "Story-04.1"},
          {"status": 403, "code": "ROLE_REQUIRED",    "condition": "author 권한 없음", "message": "작성 권한이 필요합니다", "lineage_quote": "Story-01.1"},
          {"status": 422, "code": "VALIDATION_ERROR", "condition": "title/body 길이 초과 또는 빈 값", "message": "잘못된 입력값", "lineage_quote": "Story-01.1"}
        ],
        "auth": {
          "required": true, "required_roles": ["author", "admin"],
          "ownership_check": "self-as-author",
          "description": "author 또는 admin"
        }
      },
      {
        "id": "API-02", "name": "게시글 목록 조회", "method": "GET", "endpoint": "/api/v1/posts",
        "description": "활성 게시글 목록 조회. guest 도 가능.",
        "related_story_id": "Story-01.2",
        "path_params": [],
        "query_params": [
          {"name": "page",     "type": "integer", "required": false, "constraint": ">=1",          "description": "페이지 (기본 1)"},
          {"name": "pageSize", "type": "integer", "required": false, "constraint": "1~100",        "description": "페이지 크기 (기본 20)"},
          {"name": "tag",      "type": "string",  "required": false, "constraint": "",              "description": "태그 필터"},
          {"name": "authorId", "type": "uuid",    "required": false, "constraint": "",              "description": "작성자 필터"}
        ],
        "request_body": {"content_type": "", "fields": [], "example": ""},
        "response_body": {
          "status": 200, "content_type": "application/json",
          "fields": [
            {"name": "items", "type": "array",   "required": true, "constraint": "item: Post (status=PUBLISHED 만)", "description": "게시글 목록"},
            {"name": "total", "type": "integer", "required": true, "constraint": "",                                   "description": "전체 개수"}
          ],
          "example": "{\"items\": [...], \"total\": 1024}"
        },
        "error_cases": [
          {"status": 422, "code": "VALIDATION_ERROR", "condition": "pageSize 초과", "message": "잘못된 입력값", "lineage_quote": "Story-01.2"}
        ],
        "auth": {
          "required": false, "required_roles": [],
          "ownership_check": "",
          "description": "guest 가능. DELETED/HIDDEN 게시글은 owner+admin 만 조회 가능 (별도 쿼리)."
        }
      },
      {
        "id": "API-03", "name": "게시글 수정", "method": "PATCH", "endpoint": "/api/v1/posts/{postId}",
        "description": "본인 게시글 수정. admin 도 가능 (모더레이션).",
        "related_story_id": "Story-01.3",
        "path_params": [
          {"name": "postId", "type": "uuid", "required": true, "constraint": "", "description": "게시글 ID"}
        ],
        "query_params": [],
        "request_body": {
          "content_type": "application/json",
          "fields": [
            {"name": "title", "type": "string", "required": false, "constraint": "1~200자",   "description": "제목"},
            {"name": "body",  "type": "string", "required": false, "constraint": "1~50000자", "description": "본문"},
            {"name": "tags",  "type": "array",  "required": false, "constraint": "최대 10개", "description": "태그"}
          ],
          "example": "{\"title\": \"수정된 제목\"}"
        },
        "response_body": {
          "status": 200, "content_type": "application/json",
          "fields": [
            {"name": "id",        "type": "uuid",     "required": true, "constraint": "", "description": ""},
            {"name": "updatedAt", "type": "datetime", "required": true, "constraint": "", "description": "UTC"}
          ],
          "example": "{\"id\": \"...\", \"updatedAt\": \"2026-05-26T...\"}"
        },
        "error_cases": [
          {"status": 401, "code": "AUTH_REQUIRED",    "condition": "JWT 누락/만료",        "message": "인증이 필요합니다",      "lineage_quote": "Story-04.1"},
          {"status": 403, "code": "FORBIDDEN_OWNER",  "condition": "본인 게시글 + admin 아님", "message": "권한이 없습니다",        "lineage_quote": "Story-01.3"},
          {"status": 404, "code": "POST_NOT_FOUND",   "condition": "postId 미존재",         "message": "게시글을 찾을 수 없습니다", "lineage_quote": "Story-01.4"},
          {"status": 422, "code": "VALIDATION_ERROR", "condition": "title/body 길이 초과", "message": "잘못된 입력값",          "lineage_quote": "Story-01.3"}
        ],
        "auth": {
          "required": true, "required_roles": ["author", "admin"],
          "ownership_check": "Post.authorId == requester.userId OR requester.role == 'admin'",
          "description": "본인 게시글 또는 admin"
        }
      },
      {
        "id": "API-04", "name": "댓글 등록", "method": "POST", "endpoint": "/api/v1/posts/{postId}/comments",
        "description": "인증된 viewer 가 댓글을 단다.",
        "related_story_id": "Story-02.1",
        "path_params": [
          {"name": "postId", "type": "uuid", "required": true, "constraint": "", "description": "게시글 ID"}
        ],
        "query_params": [],
        "request_body": {
          "content_type": "application/json",
          "fields": [
            {"name": "body", "type": "string", "required": true, "constraint": "1~2000자", "description": "댓글 본문"}
          ],
          "example": "{\"body\": \"좋은 글이네요\"}"
        },
        "response_body": {
          "status": 201, "content_type": "application/json",
          "fields": [
            {"name": "id",        "type": "uuid",     "required": true, "constraint": "", "description": "댓글 ID"},
            {"name": "createdAt", "type": "datetime", "required": true, "constraint": "", "description": "UTC"}
          ],
          "example": "{\"id\": \"...\", \"createdAt\": \"2026-05-26T...\"}"
        },
        "error_cases": [
          {"status": 401, "code": "AUTH_REQUIRED",    "condition": "JWT 누락/만료",        "message": "인증이 필요합니다",      "lineage_quote": "Story-04.1"},
          {"status": 404, "code": "POST_NOT_FOUND",   "condition": "postId 미존재",         "message": "게시글을 찾을 수 없습니다", "lineage_quote": "Story-02.1"},
          {"status": 409, "code": "STATE_CONFLICT",   "condition": "게시글 status=DELETED/HIDDEN", "message": "이 게시글에는 댓글을 달 수 없습니다", "lineage_quote": "Story-02.1"},
          {"status": 422, "code": "VALIDATION_ERROR", "condition": "body 길이 초과 또는 빈 값", "message": "잘못된 입력값",       "lineage_quote": "Story-02.1"}
        ],
        "auth": {
          "required": true, "required_roles": ["viewer", "author", "admin"],
          "ownership_check": "",
          "description": "인증된 모든 사용자. guest 차단."
        }
      },
      {
        "id": "API-05", "name": "좋아요 토글", "method": "POST", "endpoint": "/api/v1/posts/{postId}/like",
        "description": "게시글 좋아요 토글 (멱등 — 이미 누른 경우 해제).",
        "related_story_id": "Story-03.1",
        "path_params": [
          {"name": "postId", "type": "uuid", "required": true, "constraint": "", "description": "게시글 ID"}
        ],
        "query_params": [],
        "request_body": {"content_type": "", "fields": [], "example": ""},
        "response_body": {
          "status": 200, "content_type": "application/json",
          "fields": [
            {"name": "liked",     "type": "boolean", "required": true, "constraint": "", "description": "토글 후 상태 (true=좋아요됨, false=해제됨)"},
            {"name": "likeCount", "type": "integer", "required": true, "constraint": "", "description": "현재 총 좋아요 수"}
          ],
          "example": "{\"liked\": true, \"likeCount\": 42}"
        },
        "error_cases": [
          {"status": 401, "code": "AUTH_REQUIRED",    "condition": "JWT 누락/만료",         "message": "인증이 필요합니다",     "lineage_quote": "Story-04.1"},
          {"status": 404, "code": "POST_NOT_FOUND",   "condition": "postId 미존재",          "message": "게시글을 찾을 수 없습니다", "lineage_quote": "Story-03.1"},
          {"status": 422, "code": "VALIDATION_ERROR", "condition": "DELETED 게시글에 좋아요", "message": "잘못된 요청입니다",     "lineage_quote": "Story-03.1"}
        ],
        "auth": {
          "required": true, "required_roles": ["viewer", "author", "admin"],
          "ownership_check": "",
          "description": "인증된 사용자. guest 차단."
        }
      }
    ],
    "entities": [
      {
        "id": "ENT-01", "name": "Post",
        "attributes": [
          {"name": "id",        "type": "uuid",     "required": true,  "constraint": "PK"},
          {"name": "authorId",  "type": "uuid",     "required": true,  "constraint": "FK -> User.id"},
          {"name": "title",     "type": "string",   "required": true,  "constraint": "1~200자"},
          {"name": "body",      "type": "string",   "required": true,  "constraint": "1~50000자"},
          {"name": "tags",      "type": "array",    "required": false, "constraint": "최대 10개"},
          {"name": "status",    "type": "enum",     "required": true,  "constraint": "PUBLISHED|DELETED|HIDDEN, 기본 PUBLISHED"},
          {"name": "likeCount", "type": "integer",  "required": true,  "constraint": ">=0, 캐시 컬럼"},
          {"name": "viewCount", "type": "integer",  "required": true,  "constraint": ">=0, 캐시 컬럼"},
          {"name": "createdAt", "type": "datetime", "required": true,  "constraint": "UTC"},
          {"name": "updatedAt", "type": "datetime", "required": true,  "constraint": "UTC"}
        ],
        "lineage": {"confidence": "direct", "related_stories": [
          {"story_id": "Story-01.1", "quote": "게시글 등록"},
          {"story_id": "Story-01.3", "quote": "게시글 수정"},
          {"story_id": "Story-01.4", "quote": "게시글 삭제"}
        ]}
      },
      {
        "id": "ENT-02", "name": "Comment",
        "attributes": [
          {"name": "id",        "type": "uuid",     "required": true, "constraint": "PK"},
          {"name": "postId",    "type": "uuid",     "required": true, "constraint": "FK -> Post.id, CASCADE 안 함 (참조 무결성)"},
          {"name": "authorId",  "type": "uuid",     "required": true, "constraint": "FK -> User.id"},
          {"name": "body",      "type": "string",   "required": true, "constraint": "1~2000자"},
          {"name": "status",    "type": "enum",     "required": true, "constraint": "VISIBLE|HIDDEN, 기본 VISIBLE"},
          {"name": "createdAt", "type": "datetime", "required": true, "constraint": "UTC"}
        ],
        "lineage": {"confidence": "direct", "related_stories": [
          {"story_id": "Story-02.1", "quote": "댓글 등록"},
          {"story_id": "Story-02.2", "quote": "댓글 모더레이션"}
        ]}
      },
      {
        "id": "ENT-03", "name": "PostLike",
        "attributes": [
          {"name": "postId",  "type": "uuid",     "required": true, "constraint": "PK (postId, userId)"},
          {"name": "userId",  "type": "uuid",     "required": true, "constraint": "PK (postId, userId), UNIQUE"},
          {"name": "likedAt", "type": "datetime", "required": true, "constraint": "UTC"}
        ],
        "lineage": {"confidence": "direct", "related_stories": [
          {"story_id": "Story-03.1", "quote": "좋아요 토글"}
        ]}
      },
      {
        "id": "ENT-04", "name": "User",
        "attributes": [
          {"name": "id",           "type": "uuid",     "required": true, "constraint": "PK"},
          {"name": "email",        "type": "string",   "required": true, "constraint": "UNIQUE, 유효 이메일"},
          {"name": "passwordHash", "type": "string",   "required": true, "constraint": "Argon2"},
          {"name": "role",         "type": "enum",     "required": true, "constraint": "author|viewer|admin, 기본 viewer"},
          {"name": "createdAt",    "type": "datetime", "required": true, "constraint": "UTC"}
        ],
        "lineage": {"confidence": "direct", "related_stories": [
          {"story_id": "Story-04.1", "quote": "사용자 계정"}
        ]}
      }
    ],
    "policies": [
      {"id": "POL-01", "category": "Availability", "description": "가동률 99.9% 이상 (NFR-01)"},
      {"id": "POL-02", "category": "Performance",  "description": "API 응답 95th percentile 500ms 이내 (NFR-03)"},
      {"id": "POL-03", "category": "Performance",  "description": "게시글 조회 캐시 60초, 좋아요/댓글 카운트 stale 허용 (NFR-04)"},
      {"id": "POL-04", "category": "Scalability",  "description": "100만 건까지 페이지네이션 (NFR-05)"},
      {"id": "POL-05", "category": "Security",     "description": "사용자 데이터 암호화 + RBAC (NFR-06)"},
      {"id": "POL-06", "category": "Security",     "description": "OAuth 2.0 + HTTPS (NFR-07)"}
    ]
  },
  "ddd": {
    "contexts": [
      {"id": "CTX-01", "name": "Content"},
      {"id": "CTX-02", "name": "Identity"}
    ],
    "aggregates": [
      {"id": "AGG-01", "name": "Post", "context_id": "CTX-01",
       "lineage": {"confidence": "direct", "related_stories": [
         {"story_id": "Story-01.1", "quote": "게시글 등록"},
         {"story_id": "Story-01.3", "quote": "게시글 수정"}
       ]},
       "invariants": [
         "authorId 는 등록 시 1회 set 후 불변",
         "status 전이: PUBLISHED → DELETED 또는 PUBLISHED → HIDDEN (admin 만)",
         "DELETED 게시글에도 Comment 는 보존 (참조 무결성)",
         "likeCount = SELECT count(*) FROM PostLike WHERE postId = this.id (캐시 동기화)"
       ]},
      {"id": "AGG-02", "name": "Comment", "context_id": "CTX-01",
       "lineage": {"confidence": "direct", "related_stories": [
         {"story_id": "Story-02.1", "quote": "댓글 등록"},
         {"story_id": "Story-02.2", "quote": "모더레이션"}
       ]},
       "invariants": [
         "postId 는 등록 시 1회 set 후 불변",
         "status in {VISIBLE, HIDDEN}",
         "Post.status != PUBLISHED 인 게시글에는 신규 Comment 생성 금지 (409)"
       ]},
      {"id": "AGG-03", "name": "User", "context_id": "CTX-02",
       "lineage": {"confidence": "direct", "related_stories": [
         {"story_id": "Story-04.1", "quote": "사용자 계정"}
       ]},
       "invariants": [
         "email 형식 검증 + UNIQUE",
         "passwordHash 는 Argon2 (평문 저장 금지)",
         "role in {author, viewer, admin}"
       ]}
    ]
  },
  "arch": {
    "services": [
      {"id": "SVC-01", "name": "블로그 서비스", "type": "Backend API", "tech_stack": "FastAPI",
       "deployment": {
         "port": 8000, "replicas": 3,
         "health_check_path": "/health",
         "env_vars": ["DATABASE_URL", "REDIS_URL", "JWT_SECRET"],
         "scaling_policy": "auto-cpu"
       },
       "external_dependencies": []},
      {"id": "SVC-02", "name": "인증 서비스", "type": "Backend API", "tech_stack": "FastAPI",
       "deployment": {
         "port": 8001, "replicas": 2,
         "health_check_path": "/health",
         "env_vars": ["DATABASE_URL", "JWT_SECRET"],
         "scaling_policy": "manual"
       },
       "external_dependencies": []},
      {"id": "SVC-03", "name": "블로그 프론트엔드", "type": "Frontend", "tech_stack": "Next.js",
       "deployment": {"port": 0, "replicas": 1, "health_check_path": "", "env_vars": [], "scaling_policy": "manual"},
       "external_dependencies": []}
    ],
    "databases": [
      {"id": "DB-01", "name": "주 데이터베이스", "type": "Relational Database", "tech_stack": "PostgreSQL"},
      {"id": "DB-02", "name": "조회 캐시",        "type": "In-Memory",           "tech_stack": "Redis"}
    ],
    "connections": [
      {"source_id": "SVC-03", "target_id": "SVC-01", "protocol": "HTTPS/REST", "description": "블로그 API",   "auth": "bearer"},
      {"source_id": "SVC-03", "target_id": "SVC-02", "protocol": "HTTPS/REST", "description": "인증 API",      "auth": "bearer"},
      {"source_id": "SVC-01", "target_id": "DB-01",  "protocol": "SQL/TCP",    "description": "블로그 데이터", "auth": "basic"},
      {"source_id": "SVC-01", "target_id": "DB-02",  "protocol": "Redis Wire", "description": "조회 캐시",     "auth": "basic"},
      {"source_id": "SVC-02", "target_id": "DB-01",  "protocol": "SQL/TCP",    "description": "사용자 데이터", "auth": "basic"}
    ]
  },
