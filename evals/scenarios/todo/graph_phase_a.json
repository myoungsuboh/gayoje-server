{
  "spack": {
    "apis": [
      {
        "id": "API-01",
        "name": "할 일 등록",
        "method": "POST",
        "endpoint": "/api/v1/todos",
        "description": "새 할 일을 등록한다.",
        "related_story_id": "Story-01.1",
        "path_params": [],
        "query_params": [],
        "request_body": {
          "content_type": "application/json",
          "fields": [
            {"name": "title",       "type": "string",   "required": true,  "constraint": "1~200자",                 "description": "할 일 제목"},
            {"name": "description", "type": "string",   "required": false, "constraint": "5000자 이내",             "description": "상세 설명"},
            {"name": "dueDate",     "type": "datetime", "required": false, "constraint": "UTC ISO-8601, 미래 시점", "description": "마감일"},
            {"name": "priority",    "type": "enum",     "required": false, "constraint": "enum: LOW|MEDIUM|HIGH",   "description": "우선순위 (기본 MEDIUM)"}
          ],
          "example": "{\"title\": \"보고서 작성\", \"priority\": \"HIGH\", \"dueDate\": \"2026-06-01T18:00:00Z\"}"
        },
        "response_body": {
          "status": 201, "content_type": "application/json",
          "fields": [
            {"name": "id",        "type": "uuid",     "required": true, "constraint": "", "description": "생성된 할 일 ID"},
            {"name": "createdAt", "type": "datetime", "required": true, "constraint": "", "description": "생성 시각 (UTC)"}
          ],
          "example": "{\"id\": \"...\", \"createdAt\": \"2026-05-26T...\"}"
        },
        "error_cases": [
          {"status": 401, "code": "AUTH_REQUIRED",    "condition": "JWT 누락/만료",                   "message": "인증이 필요합니다",   "lineage_quote": "Story-04.1"},
          {"status": 422, "code": "VALIDATION_ERROR", "condition": "title 길이 초과, dueDate 과거", "message": "잘못된 입력값",       "lineage_quote": "Story-01.1"}
        ],
        "auth": {
          "required": true, "required_roles": ["owner"],
          "ownership_check": "requester.userId 가 ownerId 로 자동 세팅",
          "description": "인증된 사용자만"
        }
      },
      {
        "id": "API-02",
        "name": "할 일 목록 조회",
        "method": "GET",
        "endpoint": "/api/v1/todos",
        "description": "본인의 할 일 목록을 조회한다.",
        "related_story_id": "Story-01.2",
        "path_params": [],
        "query_params": [
          {"name": "status",   "type": "enum",   "required": false, "constraint": "enum: PENDING|DONE|ARCHIVED", "description": "상태 필터"},
          {"name": "priority", "type": "enum",   "required": false, "constraint": "enum: LOW|MEDIUM|HIGH",       "description": "우선순위 필터"},
          {"name": "sort",     "type": "string", "required": false, "constraint": "createdAt|dueDate",          "description": "정렬 (기본 createdAt 내림차순)"},
          {"name": "page",     "type": "integer","required": false, "constraint": ">=1",                         "description": "페이지 (기본 1)"},
          {"name": "pageSize", "type": "integer","required": false, "constraint": "1~100",                       "description": "페이지 크기 (기본 20)"}
        ],
        "request_body": {"content_type": "", "fields": [], "example": ""},
        "response_body": {
          "status": 200, "content_type": "application/json",
          "fields": [
            {"name": "items",      "type": "array",   "required": true, "constraint": "item: Todo", "description": "할 일 목록"},
            {"name": "total",      "type": "integer", "required": true, "constraint": "",            "description": "전체 개수"},
            {"name": "page",       "type": "integer", "required": true, "constraint": "",            "description": "현재 페이지"}
          ],
          "example": "{\"items\": [...], \"total\": 142, \"page\": 1}"
        },
        "error_cases": [
          {"status": 401, "code": "AUTH_REQUIRED",    "condition": "JWT 누락/만료", "message": "인증이 필요합니다", "lineage_quote": "Story-04.1"},
          {"status": 422, "code": "VALIDATION_ERROR", "condition": "pageSize 범위 초과", "message": "잘못된 입력값", "lineage_quote": "Story-01.2"}
        ],
        "auth": {
          "required": true, "required_roles": ["owner", "admin"],
          "ownership_check": "owner: 본인만 / admin: 전체 조회 가능",
          "description": "본인 할 일 또는 관리자"
        }
      },
      {
        "id": "API-03",
        "name": "할 일 수정",
        "method": "PATCH",
        "endpoint": "/api/v1/todos/{todoId}",
        "description": "할 일을 부분 갱신한다.",
        "related_story_id": "Story-01.3",
        "path_params": [
          {"name": "todoId", "type": "uuid", "required": true, "constraint": "", "description": "할 일 식별자"}
        ],
        "query_params": [],
        "request_body": {
          "content_type": "application/json",
          "fields": [
            {"name": "title",       "type": "string",   "required": false, "constraint": "1~200자",                       "description": "제목"},
            {"name": "description", "type": "string",   "required": false, "constraint": "5000자 이내",                   "description": "상세 설명"},
            {"name": "dueDate",     "type": "datetime", "required": false, "constraint": "UTC ISO-8601",                  "description": "마감일"},
            {"name": "priority",    "type": "enum",     "required": false, "constraint": "enum: LOW|MEDIUM|HIGH",         "description": "우선순위"},
            {"name": "status",      "type": "enum",     "required": false, "constraint": "enum: PENDING|DONE|ARCHIVED",   "description": "상태"}
          ],
          "example": "{\"status\": \"ARCHIVED\"}"
        },
        "response_body": {
          "status": 200, "content_type": "application/json",
          "fields": [
            {"name": "id",        "type": "uuid",     "required": true, "constraint": "", "description": "할 일 ID"},
            {"name": "updatedAt", "type": "datetime", "required": true, "constraint": "", "description": "갱신 시각 (UTC)"}
          ],
          "example": "{\"id\": \"...\", \"updatedAt\": \"2026-05-26T...\"}"
        },
        "error_cases": [
          {"status": 401, "code": "AUTH_REQUIRED",     "condition": "JWT 누락/만료",       "message": "인증이 필요합니다",       "lineage_quote": "Story-04.1"},
          {"status": 403, "code": "FORBIDDEN_OWNER",   "condition": "본인 소유 아닌 할 일", "message": "권한이 없습니다",         "lineage_quote": "Story-01.3"},
          {"status": 404, "code": "TODO_NOT_FOUND",    "condition": "todoId 미존재",         "message": "할 일을 찾을 수 없습니다", "lineage_quote": "Story-01.4"},
          {"status": 422, "code": "VALIDATION_ERROR",  "condition": "enum 외 값, 길이 초과", "message": "잘못된 입력값",           "lineage_quote": "Story-01.3"}
        ],
        "auth": {
          "required": true, "required_roles": ["owner"],
          "ownership_check": "Todo.ownerId == requester.userId",
          "description": "본인 할 일에만 수정 가능"
        }
      },
      {
        "id": "API-04",
        "name": "할 일 삭제",
        "method": "DELETE",
        "endpoint": "/api/v1/todos/{todoId}",
        "description": "할 일을 삭제한다.",
        "related_story_id": "Story-01.4",
        "path_params": [
          {"name": "todoId", "type": "uuid", "required": true, "constraint": "", "description": "할 일 식별자"}
        ],
        "query_params": [],
        "request_body": {"content_type": "", "fields": [], "example": ""},
        "response_body": {"status": 204, "content_type": "", "fields": [], "example": ""},
        "error_cases": [
          {"status": 401, "code": "AUTH_REQUIRED",   "condition": "JWT 누락/만료",       "message": "인증이 필요합니다",       "lineage_quote": "Story-04.1"},
          {"status": 403, "code": "FORBIDDEN_OWNER", "condition": "본인 소유 아닌 할 일", "message": "권한이 없습니다",         "lineage_quote": "Story-01.4"},
          {"status": 404, "code": "TODO_NOT_FOUND",  "condition": "todoId 미존재",         "message": "할 일을 찾을 수 없습니다", "lineage_quote": "Story-01.4"}
        ],
        "auth": {
          "required": true, "required_roles": ["owner"],
          "ownership_check": "Todo.ownerId == requester.userId",
          "description": "본인 할 일에만 삭제 가능"
        }
      },
      {
        "id": "API-05",
        "name": "할 일 완료",
        "method": "POST",
        "endpoint": "/api/v1/todos/{todoId}/complete",
        "description": "할 일을 완료 상태(DONE) 로 전환한다.",
        "related_story_id": "Story-02.1",
        "path_params": [
          {"name": "todoId", "type": "uuid", "required": true, "constraint": "", "description": "할 일 식별자"}
        ],
        "query_params": [],
        "request_body": {"content_type": "", "fields": [], "example": ""},
        "response_body": {
          "status": 200, "content_type": "application/json",
          "fields": [
            {"name": "id",          "type": "uuid",     "required": true, "constraint": "", "description": "할 일 ID"},
            {"name": "status",      "type": "enum",     "required": true, "constraint": "DONE", "description": "변경 후 상태 (항상 DONE)"},
            {"name": "completedAt", "type": "datetime", "required": true, "constraint": "", "description": "완료 시각 (UTC)"}
          ],
          "example": "{\"id\": \"...\", \"status\": \"DONE\", \"completedAt\": \"2026-05-26T...\"}"
        },
        "error_cases": [
          {"status": 401, "code": "AUTH_REQUIRED",   "condition": "JWT 누락/만료",         "message": "인증이 필요합니다",       "lineage_quote": "Story-04.1"},
          {"status": 403, "code": "FORBIDDEN_OWNER", "condition": "본인 소유 아닌 할 일",   "message": "권한이 없습니다",         "lineage_quote": "Story-02.1"},
          {"status": 404, "code": "TODO_NOT_FOUND",  "condition": "todoId 미존재",           "message": "할 일을 찾을 수 없습니다", "lineage_quote": "Story-02.1"},
          {"status": 409, "code": "ALREADY_DONE",    "condition": "이미 DONE 인 할 일",     "message": "이미 완료된 할 일입니다", "lineage_quote": "Story-02.1"}
        ],
        "auth": {
          "required": true, "required_roles": ["owner"],
          "ownership_check": "Todo.ownerId == requester.userId",
          "description": "본인 할 일에만 완료 가능"
        }
      }
    ],
    "entities": [
